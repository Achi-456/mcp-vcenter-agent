# .env  —  copy this file to .env and fill in your real values

# ─── LLM providers (set the keys for the ones you want to use) ───
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY
# OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
# GOOGLE_API_KEY=REPLACE_WITH_YOUR_KEY           # for Gemini
# XAI_API_KEY=REPLACE_WITH_YOUR_KEY              # for Grok (OpenAI-compatible)

# VMware vCenter (used by API + govc; GOVC vars optional — derived from these if missing)
VCENTER_HOST=core-infra-vc01.dclab.com
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=REPLACE_WITH_YOUR_PASSWORD
VCENTER_PORT=443

# govc (optional overrides; if unset, GOVC_URL is built as https://VCENTER_HOST:VCENTER_PORT/sdk)
# GOVC_URL=https://core-infra-vc01.dclab.com:443/sdk
# GOVC_INSECURE=1

# Tavily (enables web_search tool in the agent)
# TAVILY_API_KEY=

# Agent loop (web + CLI)
# AGENT_PROVIDER=anthropic            # anthropic | openai | gemini | grok
# AGENT_FALLBACK_PROVIDER=openai      # fallback when primary hits rate limits after max retries (anthropic | openai | gemini | grok | kimi)
# AGENT_MODEL=claude-sonnet-4-20250514
# AGENT_MAX_TURNS=25
# AGENT_MAX_TOKENS=4096
# AGENT_PLANNER=0                     # 1 = pre-plan the user request (no tools)
# AGENT_REFLECTION=0                 # 1 = one follow-up nudge for incomplete tasks
# AGENT_REVIEWER=0                   # 1 = post-run peer review paragraph appended
# AGENT_ALLOW_DESTRUCTIVE_WEB=0      # 1 = allow destructive tools without per-request confirm (INSECURE)

# Agent memory (short-term, working, and long-term)
# AGENT_SUMMARIZE_EVERY=8            # compress old turns every N turns (0 = disable rolling summary)
# AGENT_ENTITY_CACHE=1               # 1 = inject known VM/host/datastore names as context each turn
# AGENT_SESSION_STORE=0              # 1 = persist session summaries to SQLite for cross-restart resume
# AGENT_SESSION_DB=.data/sessions.db # path to the SQLite sessions database

# Copy lines above to .env; optional keys are also read from the host when using docker compose env_file.
